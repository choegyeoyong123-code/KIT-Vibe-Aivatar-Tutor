# See https://help.github.com/articles/ignoring-files/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.nyc_output
/playwright-report/
/test-results/

# next.js
/.next/
/out/

# production
/build
/dist

# local policy / vector store
/data/

# generated TTS / media / avatar outputs
/public/media-output/
/public/avatar-cache/
/public/avatar-output/

# IDE / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# certs / keys
*.pem
*.p12

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env — 비밀은 절대 커밋하지 않음 (예시만 커밋)
.env*
!.env.example

# vercel / turbo
.vercel
.turbo

# typescript
*.tsbuildinfo
next-env.d.ts
